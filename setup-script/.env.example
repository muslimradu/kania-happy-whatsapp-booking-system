# ─── Salin file ini menjadi .env lalu isi nilainya ───────────────────────────

# ID Spreadsheet — ambil dari URL:
# https://docs.google.com/spreadsheets/d/[ID_INI]/edit
GOOGLE_SPREADSHEET_ID=107LZdGvM6XxBZaA33E6IWwh4JtmTlcz_1onpagQ5zgw

# Email Service Account Google (dari file credentials JSON yang Anda download)
# Format: nama-akun@nama-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Private Key Service Account (salin seluruh blok dari credentials JSON,
# termasuk -----BEGIN PRIVATE KEY----- dan -----END PRIVATE KEY-----)
# Ganti newline dengan \n agar bisa disimpan dalam satu baris .env
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
