# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
TIMEZONE=Asia/Jakarta
LOG_LEVEL=info

# ── Admin & Auth ──────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ganti_password_aman
JWT_SECRET=ganti_dengan_random_string_minimal_32_karakter
JWT_EXPIRES_IN=1h

# ── Google Spreadsheet ────────────────────────────────────────────────────────
GOOGLE_SPREADSHEET_ID=id_spreadsheet_anda
GOOGLE_SERVICE_ACCOUNT_EMAIL=nama@project.iam.gserviceaccount.com
# Salin isi private key dari file JSON service account (termasuk \n)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── WhatsApp (Baileys) ────────────────────────────────────────────────────────
# Folder penyimpanan session Baileys (relatif terhadap root server)
BAILEYS_SESSION_DIR=./sessions/baileys
# Opsional: nomor WA yang digunakan (hanya untuk referensi/logging)
# BAILEYS_PHONE_NUMBER=628xxxxxxxxxx

# ── AI (Opsional) ─────────────────────────────────────────────────────────────
AI_ENABLED=true
# Wajib diisi jika AI_ENABLED=true
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Konfigurasi Bisnis ────────────────────────────────────────────────────────
# Berapa hari ke depan jadwal ditampilkan ke customer
SCHEDULE_LOOKAHEAD_DAYS=7
# Berapa menit bot berhenti membalas setelah admin takeover
TAKEOVER_TIMEOUT_MINUTES=30
# TTL cache Google Sheets (detik). 0 = nonaktifkan cache
SHEET_CACHE_TTL_SECONDS=60
